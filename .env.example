# eWeLink 智能继电器 - 真实凭据
# ⚠️ 此文件已加入 .gitignore,不会被推到 GitHub
# 复制此文件为 .env,填入你的真实值

# eWeLink 登录账号(纯手机号,代码会自动加 +86 前缀)
EWELINK_PHONE=182xxxxxxxx

# eWeLink 登录密码
EWELINK_PASSWORD=your_password_here

# eWeLink Appid (从 SonoffLAN 项目反推的社区共知凭证)
EWELINK_APPID=R8Oqxxxxxxxxxxxxxxxxxxx

# eWeLink AppSecret(签名用,绝对不能公开!)
EWELINK_APPSECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# eWeLink 设备 ID (易微联 App → 设备 → 设备信息)
EWELINK_DEVICE_ID=1002xxxxxxxx

# 账号区域: cn / us / eu / as
EWELINK_REGION=cn
